# ── Goodvibes LTD activation system — SERVER-SIDE env vars ──
# Set these in the Vercel project (Settings → Environment Variables).
# They are used only by the /api serverless functions. Never expose the
# service-role key to the browser.

# Supabase project (RealMatch): https://rkthpfdzzisudaxxqvgn.supabase.co
SUPABASE_URL=https://rkthpfdzzisudaxxqvgn.supabase.co

# Supabase SERVICE ROLE key (secret). Supabase dashboard → Project Settings →
# API → service_role. Bypasses RLS; keep it server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to HMAC the preview browser token before hashing/storing it.
# Any long random string (e.g. `openssl rand -hex 32`).
PREVIEW_COOKIE_SECRET=

# Shared secret protecting the inbound GCash-email webhook.
# The inbound-email provider must send this as the `X-Webhook-Secret` header
# (or `?secret=` query param). Generate with `openssl rand -hex 32`.
GOODVIBES_INBOUND_EMAIL_SECRET=
